# Copy to ".env" and fill in. Values prefixed PUBLIC_ are exposed to the browser.

# (Optional) Web3Forms access key (https://web3forms.com, free).
# The contact form emails submissions through Web3Forms. Set this in Vercel if
# you want to override the checked-in public key.
PUBLIC_WEB3FORMS_KEY=

# --- Keystatic GitHub mode — REQUIRED on Vercel for the live admin (/keystatic) ---
# The deployed admin uses GitHub storage (see keystatic.config.ts). Set these in the
# Vercel project's Environment Variables (Production). Get CLIENT_ID/SECRET + the app
# slug from the GitHub App setup shown at /keystatic on first deploy. KEYSTATIC_SECRET
# is any long random string you generate (e.g. `openssl rand -hex 32`).
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=
# PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
