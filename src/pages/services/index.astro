---
import Base from '../../layouts/Base.astro';
import T from '../../components/T.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import SocialDmPanel from '../../components/SocialDmPanel.astro';
import { services } from '../../data/services';
import { getServiceOffers } from '../../lib/content';
import { t } from '../../i18n/ui';

const serviceOffers = await getServiceOffers();
---
<Base
  title={t('home.services.title', 'en')}
  active="services"
>
  <div class="wrap">
    <section class="sec page-hero services-hero" data-reveal="page-hero">
      <h1 class="lead-title"><T k="home.services.title" /></h1>
      <!-- compliance up front: what we do / don't -->
      <T k="svcDetail.dont.body" tag="p" class="t-body" />
    </section>
    <section class="sec page-content" data-reveal="section">
      <div class="grid-services services-page-grid" data-reveal="stagger" data-stagger>
        {services.map((service) => <ServiceCard service={service} offer={serviceOffers[service.id]} />)}
      </div>
    </section>
    <section class="sec visa-hub-dm" data-reveal="cta">
      <SocialDmPanel context="general" source="services-hub" id="dm" compact />
    </section>
  </div>
</Base>
