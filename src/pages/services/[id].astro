---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import T from '../../components/T.astro';
import SocialDmPanel from '../../components/SocialDmPanel.astro';
import MobileSocialDm from '../../components/MobileSocialDm.astro';
import { services, type Service } from '../../data/services';
import { t } from '../../i18n/ui';

export async function getStaticPaths() {
  return services.map((s) => ({ params: { id: s.id }, props: { service: s } }));
}

const { service } = Astro.props as { service: Service };
---
<Base
  title={t(service.nameKey, 'en')}
  active="services"
  description={t(service.descKey, 'en')}
>
  <div class="wrap">
    <div class="detail-2col detail-page service-info-page">
      <article>
        <header class="detail-hero service-detail-hero" data-reveal="page-hero">
          <span class="svc-ico"><Icon name={service.iconKey} /></span>
          <h1 class="lead-title" data-i18n={service.nameKey}>{t(service.nameKey, 'en')}</h1>
          <T k={service.descKey} tag="p" class="t-sub" />
        </header>

        {service.contentSections.map((section, index) => (
          <section class:list={['sec', 'service-info-section', { 'service-source-section': index === service.contentSections.length - 1 }]} data-reveal="section">
            <div class="service-info-heading">
              <span class="sec-ico"><Icon name={section.iconKey} /></span>
              <div>
                <T k={section.titleKey} tag="h2" class="sec-title" />
                {section.introKey && <T k={section.introKey} tag="p" class="t-body" />}
              </div>
            </div>
            <div class="service-point-grid" data-stagger>
              {section.items.map((item) => item.href ? (
                <a
                  class="service-point service-point-link"
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-event={`official-source:${service.id}`}
                  data-source={item.href}
                >
                  <span class="service-point-icon" aria-hidden="true"><Icon name={item.iconKey} size={18} /></span>
                  <span class="service-point-copy">
                    <T k={item.titleKey} tag="strong" />
                    <T k={item.bodyKey} tag="span" />
                  </span>
                  <Icon name="external" size={15} class="service-point-external" />
                </a>
              ) : (
                <div class="service-point">
                  <span class="service-point-icon" aria-hidden="true"><Icon name={item.iconKey} size={18} /></span>
                  <span class="service-point-copy">
                    <T k={item.titleKey} tag="strong" />
                    <T k={item.bodyKey} tag="span" />
                  </span>
                </div>
              ))}
            </div>
          </section>
        ))}

        <!-- Compliance boundary (§7-1). Keep the fixed copy visible once. -->
        <aside class="service-boundary-note" data-reveal="section" aria-labelledby="service-boundary-title">
          <p id="service-boundary-title" class="service-boundary-title">
            <T k="svcDetail.scope.title" />
          </p>
          <p class="service-boundary-copy">
            <T k="svcDetail.dont.body" />
          </p>
        </aside>
      </article>

      <aside class="guide-dm-aside">
        <div class="sticky-card">
          <SocialDmPanel service={service.id} context="service" source="service-sidebar" id="dm" />
        </div>
      </aside>
    </div>
  </div>
  <MobileSocialDm service={service.id} context="service" />
</Base>
