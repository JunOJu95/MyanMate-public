---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import T from '../../components/T.astro';
import LocalizedText from '../../components/LocalizedText.astro';
import SocialDmPanel from '../../components/SocialDmPanel.astro';
import MobileSocialDm from '../../components/MobileSocialDm.astro';
import { services, type Service } from '../../data/services';
import { getServiceContents, type ServiceContent } from '../../lib/content';

export async function getStaticPaths() {
  const content = await getServiceContents();
  return services.map((service) => ({
    params: { id: service.id },
    props: { service, content: content[service.id] },
  }));
}

const { service, content } = Astro.props as { service: Service; content: ServiceContent };
---
<Base
  title={content.title.en}
  active="services"
  description={content.description.en}
>
  <div class="wrap">
    <div class="detail-2col detail-page service-info-page">
      <article>
        <header class="detail-hero service-detail-hero" data-reveal="page-hero">
          <span class="svc-ico"><Icon name={service.iconKey} /></span>
          <LocalizedText value={content.title} tag="h1" class="lead-title" />
          <LocalizedText value={content.description} tag="p" class="t-sub" />
        </header>

        {content.sections.map((section) => (
          <section class:list={['sec', 'service-info-section', { 'service-source-section': section.items.some((item) => item.href) }]} data-reveal="section">
            <div class="service-info-heading">
              <span class="sec-ico"><Icon name={section.icon} /></span>
              <div>
                <LocalizedText value={section.title} tag="h2" class="sec-title" />
                {Object.values(section.intro).some(Boolean) && <LocalizedText value={section.intro} tag="p" class="t-body" />}
              </div>
            </div>
            <div class="service-point-grid" data-stagger>
              {section.items.map((item) => item.href ? (
                <a
                  class="service-point service-point-link"
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-event={`official-source:${service.id}`}
                  data-source={item.href}
                >
                  <span class="service-point-icon" aria-hidden="true"><Icon name={item.icon} size={18} /></span>
                  <span class="service-point-copy">
                    <LocalizedText value={item.title} tag="strong" />
                    <LocalizedText value={item.body} />
                  </span>
                  <Icon name="external" size={15} class="service-point-external" />
                </a>
              ) : (
                <div class="service-point">
                  <span class="service-point-icon" aria-hidden="true"><Icon name={item.icon} size={18} /></span>
                  <span class="service-point-copy">
                    <LocalizedText value={item.title} tag="strong" />
                    <LocalizedText value={item.body} />
                  </span>
                </div>
              ))}
            </div>
          </section>
        ))}

        <!-- Compliance boundary (§7-1). Keep the fixed copy visible once. -->
        <aside class="service-boundary-note" data-reveal="section" aria-labelledby="service-boundary-title">
          <p id="service-boundary-title" class="service-boundary-title">
            <T k="svcDetail.scope.title" />
          </p>
          <p class="service-boundary-copy">
            <T k="svcDetail.dont.body" />
          </p>
        </aside>
      </article>

      <aside class="guide-dm-aside">
        <div class="sticky-card">
          <SocialDmPanel service={service.id} context="service" source="service-sidebar" id="dm" />
        </div>
      </aside>
    </div>
  </div>
  <MobileSocialDm service={service.id} context="service" />
</Base>
