---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import T from '../components/T.astro';
import { t } from '../i18n/ui';

const values = [
  { title: 'about.values.public.title', body: 'about.values.public.body' },
  { title: 'about.values.honest.title', body: 'about.values.honest.body' },
  { title: 'about.values.control.title', body: 'about.values.control.body' },
];
---
<Base title={t('about.title', 'en')} active="about" description={t('about.lead', 'en')}>
  <div class="wrap">
    <section class="sec hero page-hero about-hero">
      <T k="about.title" tag="h1" class="lead-title" />
      <T k="about.lead" tag="p" class="t-sub" />
    </section>

    <section class="sec about-story">
      <div class="about-story-heading">
        <span class="story-mark"><Icon name="chat" size={24} /></span>
        <T k="about.story.title" tag="h2" class="sec-title" />
      </div>
      <div class="about-story-copy">
        <T k="about.story.p1" tag="p" class="story-paragraph" />
        <T k="about.story.p2" tag="p" class="story-paragraph" />
        <T k="about.story.p3" tag="p" class="story-paragraph story-paragraph-strong" />
      </div>
    </section>

    <section class="sec about-partners">
      <T k="about.partner.title" tag="h2" class="sec-title" />
      <div class="partner-grid">
        <div class="partner-profile">
          <span class="partner-mark" aria-hidden="true"><Icon name="list" size={24} /></span>
          <div class="partner-copy">
            <span class="pill-tag" data-i18n="about.partner.kr.label">{t('about.partner.kr.label', 'en')}</span>
            <T k="about.partner.kr.body" tag="p" class="t-body mt-8" />
            <div class="partner-role">
              <T k="about.partner.role.label" tag="p" class="t-cap" />
              <T k="about.partner.kr.role" tag="p" class="card-title" />
            </div>
          </div>
        </div>
        <div class="partner-profile">
          <span class="partner-mark" aria-hidden="true"><Icon name="users" size={24} /></span>
          <div class="partner-copy">
            <span class="pill-tag" data-i18n="about.partner.mm.label">{t('about.partner.mm.label', 'en')}</span>
            <T k="about.partner.mm.body" tag="p" class="t-body mt-8" />
            <div class="partner-role">
              <T k="about.partner.role.label" tag="p" class="t-cap" />
              <T k="about.partner.mm.role" tag="p" class="card-title" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="sec about-values">
      <p class="sec-title"><span class="sec-ico"><Icon name="check" /></span><T k="about.values.title" /></p>
      <div class="value-grid">
        {values.map((value, index) => (
          <div class="value-item">
            <span class="num-badge">{index + 1}</span>
            <T k={value.title} tag="h3" class="card-title" />
            <T k={value.body} tag="p" class="t-body" />
          </div>
        ))}
      </div>
    </section>

    <section class="sec">
      <div class="cta-band">
        <T k="about.cta.note" tag="p" class="t-body" />
        <a class="btn pri full" href="/contact" data-i18n="btn.getHelp" data-event="cta:about">{t('btn.getHelp', 'en')}</a>
      </div>
    </section>
  </div>
</Base>
