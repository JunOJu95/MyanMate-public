---
import Base from '../layouts/Base.astro';
import T from '../components/T.astro';
import { t } from '../i18n/ui';
---
<Base title={t('about.title', 'en')} active="about" description={t('about.lead', 'en')}>
  <div class="wrap">
    <section class="sec hero page-hero about-hero" data-reveal="page-hero">
      <T k="about.title" tag="h1" class="lead-title" />
      <T k="about.lead" tag="p" class="t-sub" />
    </section>

    <section class="sec about-editorial">
      <div class="about-editorial-copy" data-reveal="section">
        <T k="about.story.intro" tag="p" class="about-editorial-lead" />
        <T k="about.story.chapter1.body" tag="p" class="about-editorial-p" />
        <T k="about.story.chapter2.body" tag="p" class="about-editorial-p" />
        <T k="about.story.chapter3.body" tag="p" class="about-editorial-p" />

        <blockquote class="about-editorial-quote" data-reveal="cta">
          <T k="about.story.quote" tag="p" />
        </blockquote>
      </div>
    </section>

    <section class="about-proof-strip" aria-label={t('about.proof.label', 'en')} data-reveal="section">
      <T k="about.proof.item1" tag="p" />
      <T k="about.proof.item2" tag="p" />
      <T k="about.proof.item3" tag="p" />
    </section>

    <section class="sec about-story-cta" data-reveal="cta">
      <div class="cta-band">
        <T k="about.cta.note" tag="p" class="t-body" />
        <a class="btn pri full" href="/guides" data-i18n="btn.browseGuides" data-event="about:guides">{t('btn.browseGuides', 'en')}</a>
        <a class="btn ghost full" href="/contact" data-i18n="btn.getHelp" data-event="about:contact">{t('btn.getHelp', 'en')}</a>
      </div>
    </section>
  </div>
</Base>
