---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import T from '../components/T.astro';
import ServiceCard from '../components/ServiceCard.astro';
import GuideCard from '../components/GuideCard.astro';
import TikTokTrust from '../components/TikTokTrust.astro';
import { services } from '../data/services';
import { getGuides } from '../lib/content';
import { t } from '../i18n/ui';

const guides = (await getGuides()).filter((guide) => guide.category === 'visa');
const processSteps = [
  { title: 'home.process.step1.title', body: 'home.process.step1.body' },
  { title: 'home.process.step2.title', body: 'home.process.step2.body' },
  { title: 'home.process.step3.title', body: 'home.process.step3.body' },
];
const preparationItems = [
  { icon: 'users', key: 'home.prepare.eligibility' },
  { icon: 'doc', key: 'home.prepare.documents' },
  { icon: 'check', key: 'home.prepare.validity' },
  { icon: 'list', key: 'home.prepare.order' },
  { icon: 'visa', key: 'home.prepare.official' },
];
const visaOutcomeKeys = [
  'home.visaService.outcome.requirements',
  'home.visaService.outcome.checklist',
  'home.visaService.outcome.sources',
  'home.visaService.outcome.order',
  'home.visaService.outcome.questions',
];
const visaService = services.find((service) => service.id === 'visa')!;
const otherServices = services.filter((service) => service.id !== 'visa');
---
<Base
  title=""
  active="home"
  description={t('home.hero.sub', 'en')}
  mobileCtaHref="/contact?service=visa&source=home"
  mobileCtaSentinel=".prepare-band"
  mobileCtaBlockers=".visa-service-band, .foot"
  mobileCtaEvent="home_mobile_cta"
>
  <div class="wrap home-wrap">
    <!-- hero -->
    <section class="sec home-hero" data-reveal="hero">
      <img class="hero-media" src="/images/brand/field-guide-desk.png" alt="" loading="eager" decoding="async" aria-hidden="true" />
      <div class="hero-copy" data-hero-sequence>
        <T k="home.hero.kicker" tag="p" class="eyebrow" />
        <T k="home.hero.headline" tag="h1" class="h-hero" />
        <T k="home.hero.sub" tag="p" class="t-sub" />
        <div class="hero-actions">
          <a class="btn pri" href="/contact?service=visa&source=home" data-i18n="btn.organizeVisa" data-event="home_hero_service" data-service="visa" data-source="home">{t('btn.organizeVisa', 'en')}</a>
          <a class="btn" href="/guides" data-i18n="btn.browseGuides" data-event="home_hero_guides" data-source="home">{t('btn.browseGuides', 'en')}</a>
        </div>
      </div>
      <div class="scene-panel" aria-hidden="true">
        <span class="desk-label" data-i18n="home.hero.visual.title">{t('home.hero.visual.title', 'en')}</span>
        <ul>
          <li data-i18n="home.hero.visual.item1">{t('home.hero.visual.item1', 'en')}</li>
          <li data-i18n="home.hero.visual.item2">{t('home.hero.visual.item2', 'en')}</li>
          <li data-i18n="home.hero.visual.item3">{t('home.hero.visual.item3', 'en')}</li>
        </ul>
      </div>
    </section>

    <section class="trust-strip" aria-label={t('home.trust.label', 'en')} data-i18n-aria="home.trust.label" data-reveal="stagger" data-stagger>
      <div class="trust-point"><Icon name="check" size={18} /><T k="home.trust.info" /></div>
      <div class="trust-point"><Icon name="check" size={18} /><T k="home.trust.self" /></div>
      <div class="trust-point"><Icon name="check" size={18} /><T k="home.trust.private" /></div>
    </section>

    <!-- visa information first -->
    {guides.length > 0 && (
      <section class="sec home-section guides-band visa-guides-band" data-reveal="section">
        <div class="section-head">
          <p class="sec-title"><span class="sec-ico"><Icon name="visa" /></span><T k="home.guides.title" /></p>
          <T k="home.guides.lead" tag="p" class="t-body sec-copy" />
        </div>
        <div class="visa-guide-grid" data-reveal="stagger" data-stagger>
          {guides.map((guide) => <GuideCard guide={guide} variant="featured" eventSource="home" />)}
        </div>
        <div class="section-action"><a class="btn ghost" href="/guides" data-i18n="home.guides.all">{t('home.guides.all', 'en')}</a></div>
      </section>
    )}

    <!-- honest preparation scope -->
    <section class="sec home-section prepare-band" data-reveal="section">
      <div class="section-head">
        <p class="sec-title"><span class="sec-ico"><Icon name="list" /></span><T k="home.prepare.title" /></p>
        <T k="home.prepare.lead" tag="p" class="t-body sec-copy" />
      </div>
      <div class="prepare-grid" data-reveal="stagger" data-stagger>
        {preparationItems.map((item, index) => (
          <div class="prepare-item">
            <span class="prepare-number">0{index + 1}</span>
            <span class="prepare-icon"><Icon name={item.icon} size={18} /></span>
            <T k={item.key} tag="p" class="card-title" />
          </div>
        ))}
      </div>
    </section>

    <!-- flagship visa service -->
    <section class="sec home-section visa-service-band" data-reveal="cta">
      <div class="visa-service-panel">
        <div class="visa-service-copy">
          <T k="home.visaService.eyebrow" tag="p" class="visa-service-eyebrow" />
          <T k="home.visaService.title" tag="h2" class="visa-service-title" />
          <T k="home.visaService.body" tag="p" class="t-body" />
          <div class="visa-service-meta">
            <span data-i18n={visaService.priceKey}>{t(visaService.priceKey, 'en')}</span>
            <span data-i18n={visaService.durationKey}>{t(visaService.durationKey, 'en')}</span>
          </div>
        </div>
        <div class="visa-service-outcomes">
          <T k="home.visaService.outcomesTitle" tag="p" class="card-title" />
          <div class="visa-outcome-list" data-stagger>
            {visaOutcomeKeys.map((key) => (
              <span><Icon name="check" size={16} /><T k={key} /></span>
            ))}
          </div>
        </div>
        <div class="visa-service-actions">
          <a class="btn pri" href="/contact?service=visa&source=home" data-i18n="btn.organizeVisa" data-event="home_visa_service_cta" data-service="visa" data-source="home">{t('btn.organizeVisa', 'en')}</a>
          <a class="btn ghost" href="/services/visa" data-i18n="btn.serviceScope">{t('btn.serviceScope', 'en')}</a>
        </div>
      </div>
    </section>

    <!-- process -->
    <section class="sec home-section process-band" data-reveal="section">
      <p class="sec-title"><span class="sec-ico"><Icon name="list" /></span><T k="home.process.title" /></p>
      <div class="process-strip" data-reveal="process" data-stagger>
        {processSteps.map((step, i) => (
          <div class="process-step">
            <span class="num-badge">{i + 1}</span>
            <div>
              <p class="card-title" data-i18n={step.title}>{t(step.title, 'en')}</p>
              <p class="t-body" data-i18n={step.body}>{t(step.body, 'en')}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- secondary guidance -->
    {otherServices.length > 0 && (
      <section class="sec home-section other-services-band" data-reveal="section">
        <div class="section-head">
          <p class="sec-title"><span class="sec-ico"><Icon name="help" /></span><T k="home.otherServices.title" /></p>
          <T k="home.otherServices.lead" tag="p" class="t-body sec-copy" />
        </div>
        <div class="grid-services secondary-services" data-reveal="stagger" data-stagger>
          {otherServices.map((service) => <ServiceCard service={service} variant="compact" />)}
        </div>
      </section>
    )}

    <!-- about teaser -->
    <section class="sec home-section about-band" data-reveal="section">
      <div class="about-band-heading">
        <p class="sec-title"><span class="sec-ico"><Icon name="users" /></span><T k="home.about.title" /></p>
        <T k="home.about.eyebrow" tag="p" class="about-eyebrow" />
      </div>
      <div class="about-summary">
        <T k="home.about.blurb" tag="p" class="about-summary-copy" />
        <div class="home-role-list" data-stagger>
          <div class="home-role">
            <span class="home-role-icon"><Icon name="list" size={19} /></span>
            <T k="home.about.role.kr" tag="p" class="t-body" />
          </div>
          <div class="home-role">
            <span class="home-role-icon"><Icon name="users" size={19} /></span>
            <T k="home.about.role.mm" tag="p" class="t-body" />
          </div>
        </div>
        <a class="btn" href="/about" data-i18n="home.about.cta" data-event="about:story">{t('home.about.cta', 'en')}</a>
      </div>
    </section>

    <!-- social proof -->
    <section class="sec home-section community-band" data-reveal="section">
      <TikTokTrust />
    </section>
  </div>
</Base>
