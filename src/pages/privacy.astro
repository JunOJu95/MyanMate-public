---
import Base from '../layouts/Base.astro';
import T from '../components/T.astro';
import { t } from '../i18n/ui';

// NOTE: general-information privacy policy. Have a professional review before launch (기획서 §7-1 #5).
const UPDATED = '2026-07-01';
const sections: Array<[string, string]> = [
  ['privacy.collect.title', 'privacy.collect.body'],
  ['privacy.use.title', 'privacy.use.body'],
  ['privacy.processors.title', 'privacy.processors.body'],
  ['privacy.sensitive.title', 'privacy.sensitive.body'],
  ['privacy.retention.title', 'privacy.retention.body'],
  ['privacy.contact.title', 'privacy.contact.body'],
];
---
<Base title={t('privacy.title', 'en')} description={t('privacy.lead', 'en')}>
  <div class="wrap narrow">
    <section class="sec">
      <h1 class="lead-title"><T k="privacy.title" /></h1>
      <T k="privacy.lead" tag="p" class="t-sub" />
      <p class="meta-line">
        <span class="meta-chip"><T k="privacy.updated" /> · <time datetime={UPDATED}>{UPDATED}</time></span>
      </p>
    </section>

    {sections.map(([titleK, bodyK]) => (
      <section class="sec">
        <p class="sec-title"><T k={titleK} /></p>
        <T k={bodyK} tag="p" class="t-body" />
      </section>
    ))}
  </div>
</Base>
