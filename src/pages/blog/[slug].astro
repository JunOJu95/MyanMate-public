---
import Base from '../../layouts/Base.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import { getPosts, getPost } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const data = await getPost(slug!);
if (!data) return Astro.redirect('/blog');
const { meta, bodyHtml } = data;
const date = meta.publishedDate ?? '';
---
<Base title={meta.headline} active="blog" description={meta.excerpt} image={meta.cover ?? undefined}>
  <div class="wrap narrow">
    <article class="post" lang={meta.lang}>
      {meta.cover && (
        <div class="post-hero"><img src={meta.cover} alt="" /></div>
      )}
      <h1 class="lead-title" style="margin-top:14px;">{meta.headline}</h1>
      <p class="meta-line"><span class="post-meta">{date}{meta.author ? ` · ${meta.author}` : ''}</span></p>
      <div class="prose post-prose" set:html={bodyHtml}></div>
      <Disclaimer k="content.disclaimer" class="mt-12" />
    </article>
  </div>
</Base>
