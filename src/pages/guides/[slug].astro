---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import T from '../../components/T.astro';
import GuideSection from '../../components/GuideSection.astro';
import GuideCard from '../../components/GuideCard.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import { getGuides, visaCode, type Guide, type GuideText } from '../../lib/content';
import { categoryToService } from '../../data/services';
import { t, languages } from '../../i18n/ui';

export async function getStaticPaths() {
  const guides = await getGuides();
  return guides.map((g) => ({ params: { slug: g.slug }, props: { guide: g, all: guides } }));
}

const { guide, all } = Astro.props as { guide: Guide; all: Guide[] };
const serviceId = categoryToService[guide.category];
const related = [...all.filter((g) => g.slug !== guide.slug)]
  .sort((a, b) => Number(b.category === guide.category) - Number(a.category === guide.category))
  .slice(0, 3);
const catKey = `guides.filter.${guide.category}`;
const code = visaCode(guide.slug);
const visaId = code?.toLowerCase().replace('-', '') ?? '';
const contactHref = `/contact?service=visa&visa=${visaId}&source=guide`;
// Sections are rendered in this order; empty fields (e.g. E-9 has no subtypes/notes
// imported) are filtered out so the number badges stay gapless per guide.
const SECTIONS: { field: keyof GuideText; labelKey: string; mode: 'paras' | 'ul' | 'ol' }[] = [
  { field: 'eligibility', labelKey: 'content.section.eligibility', mode: 'ul' },
  { field: 'subtypes',    labelKey: 'content.section.subtypes',    mode: 'ul' },
  { field: 'documents',   labelKey: 'content.section.documents',   mode: 'ul' },
  { field: 'steps',       labelKey: 'content.section.steps',       mode: 'ol' },
  { field: 'watchout',    labelKey: 'content.section.watchout',    mode: 'ul' },
  { field: 'notes',       labelKey: 'content.section.notes',       mode: 'ul' },
].filter((s) => languages.some((l) => (guide[l][s.field] || '').trim()));
---
<Base title={guide.en.title} active="guides" description={guide.en.summary}>
  <div class="wrap">
    <div class:list={['detail-2col detail-page', { single: !serviceId }]}>
      <article>
        <header class="detail-hero">
        <span class="pill-tag" data-i18n={catKey}>{t(catKey, 'en')}</span>
        <h1 class="lead-title">
          {languages.map((l) => <span data-lang={l}>{guide[l].title || guide.en.title}</span>)}
        </h1>
        {guide.lastReviewed && (
          <p class="meta-line">
            <span class="meta-chip">
              <Icon name="check" size={14} /> <T k="content.lastReviewed" /> · <time datetime={guide.lastReviewed}>{guide.lastReviewed}</time>
            </span>
          </p>
        )}
        <div style="margin-top:10px;">
          {languages.map((l) => <p data-lang={l} class="t-sub">{guide[l].summary || guide.en.summary}</p>)}
        </div>
        </header>
        {SECTIONS.map((s, i) => (
          <>
            <GuideSection guide={guide} field={s.field} labelKey={s.labelKey} mode={s.mode} num={i + 1} />
            {s.field === 'documents' && serviceId === 'visa' && (
              <section class="guide-inline-cta" data-reveal="cta">
                <div>
                  <p class="guide-cta-eyebrow"><span>{code}</span> <T k="content.cta.visa.eyebrow" /></p>
                  <T k="content.cta.visa.inlineTitle" tag="h2" class="card-title" />
                  <T k="content.cta.visa.body" tag="p" class="t-body" />
                </div>
                <div class="guide-inline-actions">
                  <a class="btn pri" href={contactHref} data-i18n="content.cta.visa.button" data-event="guide_cta_click" data-service="visa" data-visa={visaId} data-source="guide">{t('content.cta.visa.button', 'en')}</a>
                  <a class="btn ghost" href="/services/visa" data-i18n="btn.serviceScope">{t('btn.serviceScope', 'en')}</a>
                </div>
              </section>
            )}
          </>
        ))}

        <Disclaimer k="content.disclaimer" class="mt-12" />

        {related.length > 0 && (
          <section class="sec">
            <p class="sec-title"><span class="sec-ico"><Icon name="list" /></span><T k="content.related.title" /></p>
            <div class="grid-2">
              {related.map((r) => <GuideCard guide={r} variant="tile" />)}
            </div>
          </section>
        )}
      </article>

      {serviceId && <aside>
        <div class="card sticky-card guide-cta-card">
          <p class="guide-cta-eyebrow"><span>{code}</span> <T k="content.cta.visa.eyebrow" /></p>
          <T k="content.cta.visa.title" tag="p" class="card-title" />
          <T k="content.cta.visa.body" tag="p" class="t-body" />
          <div class="guide-cta-meta">
            <span><T k="svc.visa.price" /></span>
            <span><T k="svc.visa.duration" /></span>
          </div>
          <a class="btn pri full" href={contactHref} data-i18n="content.cta.visa.button" data-event="guide_cta_click" data-service="visa" data-visa={visaId} data-source="guide">{t('content.cta.visa.button', 'en')}</a>
          <a class="guide-scope-link" href="/services/visa" data-i18n="btn.serviceScope">{t('btn.serviceScope', 'en')}</a>
        </div>
      </aside>}
    </div>
  </div>
</Base>
