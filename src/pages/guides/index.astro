---
import Base from '../../layouts/Base.astro';
import InformationCategoryCard from '../../components/InformationCategoryCard.astro';
import T from '../../components/T.astro';
import { services } from '../../data/services';
import { getServiceContents, type LocalizedText as LocalizedTextValue } from '../../lib/content';
import { t } from '../../i18n/ui';

const serviceContent = await getServiceContents();
const fromKey = (key: string): LocalizedTextValue => ({
  en: t(key, 'en'),
  ko: t(key, 'ko'),
  my: t(key, 'my'),
});
const categories = services.map((service) => {
  if (service.id === 'visa') {
    return {
      id: service.id,
      icon: service.iconKey,
      href: '/guides/visa',
      title: fromKey('guides.title'),
      summary: fromKey('infoHub.visa.summary'),
    };
  }
  const content = serviceContent[service.id];
  return {
    id: service.id,
    icon: service.iconKey,
    href: `/guides/${service.id}`,
    title: content.title,
    summary: content.description,
  };
});
---

<Base title={t('infoHub.title', 'en')} active="guides" description={t('infoHub.intro', 'en')}>
  <div class="wrap information-hub-page">
    <section class="sec page-hero information-hub-hero" data-reveal="page-hero">
      <T k="infoHub.eyebrow" tag="p" class="visa-hub-eyebrow" />
      <h1 class="lead-title"><T k="infoHub.title" /></h1>
      <T k="infoHub.intro" tag="p" class="t-sub" />
    </section>

    <section class="sec page-content information-hub-content" data-reveal="section">
      <div class="visa-hub-heading">
        <T k="infoHub.choose" tag="h2" class="sec-title" />
        <T k="infoHub.chooseNote" tag="p" class="t-body" />
      </div>
      <div class="grid-services services-page-grid information-category-grid" data-reveal="stagger" data-stagger>
        {categories.map((category) => (
          <InformationCategoryCard
            id={category.id}
            title={category.title}
            summary={category.summary}
            href={category.href}
            icon={category.icon}
          />
        ))}
      </div>
    </section>
  </div>
</Base>
