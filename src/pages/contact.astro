---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import T from '../components/T.astro';
import SocialDmPanel from '../components/SocialDmPanel.astro';
import { t } from '../i18n/ui';

const trustItems = [
  { icon: 'check', title: 'request.trust.noSensitive.title', body: 'request.trust.noSensitive.body' },
  { icon: 'list', title: 'request.trust.self.title', body: 'request.trust.self.body' },
  { icon: 'chat', title: 'request.trust.dm.title', body: 'request.trust.dm.body' },
];
---
<Base title={t('request.title', 'en')} description={t('request.lead', 'en')}>
  <div class="wrap contact-page dm-contact-page">
    <div class="contact-intro" data-reveal="page-hero">
      <section class="sec page-hero">
        <h1 class="lead-title"><T k="request.title" /></h1>
        <T k="request.lead" tag="p" class="t-body mt-8" />
      </section>

      <section class="contact-assurance" aria-label={t('request.title', 'en')} data-i18n-aria="request.title" data-stagger>
        {trustItems.map((item) => (
          <div class="assurance-item">
            <span class="assurance-ico"><Icon name={item.icon} size={18} /></span>
            <span>
              <b data-i18n={item.title}>{t(item.title, 'en')}</b>
              <span data-i18n={item.body}>{t(item.body, 'en')}</span>
            </span>
          </div>
        ))}
      </section>
    </div>

    <section class="sec contact-dm-panel" data-reveal="cta">
      <SocialDmPanel context="general" source="contact" id="dm" />
    </section>
  </div>

  <script>
    const params = new URLSearchParams(location.search);
    const service = params.get('service');
    const visa = params.get('visa');
    const allowedServices = new Set(['visa', 'resume', 'housing']);
    const allowedVisas = new Set(['d2', 'd4', 'd10', 'e9']);

    document.querySelectorAll<HTMLElement>('.contact-dm-panel [data-channel]').forEach((link) => {
      if (service && allowedServices.has(service)) link.dataset.service = service;
      if (visa && allowedVisas.has(visa)) link.dataset.visa = visa;
    });
  </script>
</Base>
