---
/**
 * Decorative avatar (zero JS, no images). Shows initials from `name` when given,
 * otherwise a people icon. Replaces the empty `.avatar` placeholder spans.
 * Clay palette only — see global.css (.avatar.has-content / .av-mono / .av-ico).
 */
import Icon from './Icon.astro';

interface Props {
  name?: string;
  size?: number;
}
const { name, size = 48 } = Astro.props;
const initials = (name || '')
  .trim()
  .split(/[\s-]+/)
  .filter(Boolean)
  .map((w) => w[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();
const fontSize = Math.round(size * 0.36);
const iconSize = Math.round(size * 0.5);
---
<span class="avatar has-content" style={`width:${size}px;height:${size}px;`} aria-hidden="true">
  {initials
    ? <span class="av-mono" style={`font-size:${fontSize}px;`}>{initials}</span>
    : <Icon name="users" size={iconSize} class="av-ico" />}
</span>
