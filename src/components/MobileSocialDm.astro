---
import Icon from './Icon.astro';
import SocialDmPanel from './SocialDmPanel.astro';
import T from './T.astro';
import { t, defaultLang } from '../i18n/ui';

interface Props {
  visa?: string;
  service?: string;
  context?: 'visa' | 'service' | 'general';
  sentinel?: string;
  blockers?: string;
  scope?: boolean;
}

const {
  visa,
  service = 'general',
  context = service === 'visa' ? 'visa' : 'general',
  sentinel = '.detail-hero',
  blockers = '.foot',
  scope = false,
} = Astro.props;
const dialogId = `social-dm-${service}-${visa || 'general'}`;
const mobileTitleKey = scope ? 'dm.scopeCta' : 'dm.mobile.title';
const mobileActionKey = scope ? 'dm.scopeCta' : 'dm.mobile.open';
---
<aside
  class="mobile-conversion-cta mobile-dm-trigger"
  data-sticky-cta
  data-cta-sentinel={sentinel}
  data-cta-blockers={blockers}
  aria-label={t(mobileActionKey, defaultLang)}
  data-i18n-aria={mobileActionKey}
  aria-hidden="true"
  inert
>
  <span class="mobile-conversion-copy">
    <span class="mobile-conversion-icon" aria-hidden="true"><Icon name="chat" size={18} /></span>
    <span>
      <T k={mobileTitleKey} tag="strong" />
      <T k="dm.mobile.note" tag="small" />
    </span>
  </span>
  <button class="btn pri" type="button" data-dm-open={dialogId}>
    <T k={mobileActionKey} />
  </button>
</aside>

<dialog class="dm-dialog" id={dialogId} aria-label={t(mobileTitleKey, defaultLang)} data-i18n-aria={mobileTitleKey}>
  <div class="dm-sheet">
    <div class="dm-sheet-head">
      <T k={mobileTitleKey} tag="p" class="card-title" />
      <button class="dm-sheet-close" type="button" data-dm-close aria-label={t('dm.mobile.close', defaultLang)} data-i18n-aria="dm.mobile.close">
        <Icon name="close" size={20} />
      </button>
    </div>
    <SocialDmPanel service={service} visa={visa} context={context} source="mobile-dm" scope={scope} compact />
  </div>
</dialog>

<script define:vars={{ dialogId }}>
  const dialog = document.getElementById(dialogId);
  const openButton = document.querySelector(`[data-dm-open="${dialogId}"]`);
  const closeButton = dialog?.querySelector('[data-dm-close]');

  const openDialog = () => {
    if (dialog instanceof HTMLDialogElement && !dialog.open) dialog.showModal();
  };

  openButton?.addEventListener('click', openDialog);

  document.querySelectorAll('a[href="#dm"]').forEach((anchor) => {
    anchor.addEventListener('click', (event) => {
      const desktopTarget = document.getElementById('dm');
      const desktopTargetIsVisible = desktopTarget != null && desktopTarget.getClientRects().length > 0;
      if (desktopTargetIsVisible) return;

      event.preventDefault();
      openDialog();
    });
  });

  closeButton?.addEventListener('click', () => {
    if (dialog instanceof HTMLDialogElement) dialog.close();
  });
  dialog?.addEventListener('click', (event) => {
    if (event.target === dialog && dialog instanceof HTMLDialogElement) dialog.close();
  });
</script>
