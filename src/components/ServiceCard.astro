---
import Icon from './Icon.astro';
import LocalizedText from './LocalizedText.astro';
import { t, defaultLang } from '../i18n/ui';
import type { Service } from '../data/services';
import type { ServiceOffer } from '../lib/content';

interface Props {
  service: Service;
  offer: ServiceOffer;
}
const { service, offer } = Astro.props;
const href = `/services/${service.id}`;
---
<a
  class="card svc-tile svc-card-link"
  href={href}
  data-event={`service:${service.id}`}
  data-service={service.id}
  data-source="services-hub"
>
  <span class="svc-card-top">
    <span class="svc-card-title-wrap">
      <span class="svc-ico"><Icon name={service.iconKey} /></span>
      <LocalizedText value={offer.title} tag="span" class="card-title" />
    </span>
    <span class="svc-card-arrow" aria-hidden="true">→</span>
  </span>
  <span class="svc-meta">
    <span class="pill-tag" data-i18n="ui.status.available">{t('ui.status.available', defaultLang)}</span>
  </span>
  <LocalizedText value={offer.summary} tag="span" class="t-body clamp2 svc-card-summary" />
</a>
