---
import { t, defaultLang, languages } from '../i18n/ui';
import Icon from './Icon.astro';
import { categoryIcon } from '../lib/icons';
import { visaCode, type Guide } from '../lib/content';

interface Props {
  guide: Guide;
  variant?: 'row' | 'tile' | 'featured';
  eventSource?: 'home' | 'guides' | 'related';
}
const { guide, variant = 'row', eventSource = 'guides' } = Astro.props;
const href = `/guides/${guide.slug}`;
const catKey = `guides.filter.${guide.category}`;
const code = visaCode(guide.slug);
const visaId = code?.toLowerCase().replace('-', '') ?? '';
const title = (l: (typeof languages)[number]) => guide[l].title || guide.en.title;
const summary = (l: (typeof languages)[number]) => guide[l].summary || guide.en.summary;
// all-language search haystack (so search works regardless of active language)
const search = languages
  .map((l) => `${guide[l].title} ${guide[l].summary}`)
  .join(' ')
  .toLowerCase();
---
{variant === 'featured' ? (
  <a
    class="visa-guide-card"
    href={href}
    data-category={guide.category}
    data-event="visa_card_click"
    data-visa={visaId}
    data-source={eventSource}
  >
    <span class="visa-card-head">
      <span class="visa-code" aria-hidden="true">{code}</span>
      {guide.lastReviewed && (
        <span class="reviewed-mini">
          <Icon name="check" size={12} />
          <span data-i18n="content.lastReviewed">{t('content.lastReviewed', defaultLang)}</span>
          <time datetime={guide.lastReviewed}>{guide.lastReviewed}</time>
        </span>
      )}
    </span>
    <span class="visa-card-title">
      {languages.map((l) => <span data-lang={l}>{title(l)}</span>)}
    </span>
    <span class="visa-card-summary clamp3">
      {languages.map((l) => <span data-lang={l}>{summary(l)}</span>)}
    </span>
    <span class="visa-card-topics" aria-label={t('home.guideFeatures.label', defaultLang)} data-i18n-aria="home.guideFeatures.label">
      <span><Icon name="users" size={14} /><span data-i18n="home.guideFeatures.eligibility">{t('home.guideFeatures.eligibility', defaultLang)}</span></span>
      <span><Icon name="doc" size={14} /><span data-i18n="home.guideFeatures.documents">{t('home.guideFeatures.documents', defaultLang)}</span></span>
      <span><Icon name="list" size={14} /><span data-i18n="home.guideFeatures.steps">{t('home.guideFeatures.steps', defaultLang)}</span></span>
    </span>
    <span class="visa-card-action" data-i18n="btn.readVisa">{t('btn.readVisa', defaultLang)}</span>
  </a>
) : variant === 'row' ? (
  <a class="listrow guide-item" href={href} data-category={guide.category} data-search={search} data-event={`guide:${guide.slug}`}>
    <span class="thumb photo" aria-hidden="true">{code ? <span class="vbadge">{code}</span> : <Icon name={categoryIcon[guide.category] ?? 'visa'} size={24} class="glyph-ico" />}</span>
    <span class="body">
      <span class="row-title">
        {languages.map((l) => <span data-lang={l}>{title(l)}</span>)}
      </span>
      <span class="guide-meta">
        <span class="pill-tag" data-i18n={catKey}>{t(catKey, defaultLang)}</span>
        {guide.lastReviewed && (
          <span class="reviewed-mini">
            <Icon name="check" size={12} />
            <span data-i18n="content.lastReviewed">{t('content.lastReviewed', defaultLang)}</span>
            <time datetime={guide.lastReviewed}>{guide.lastReviewed}</time>
          </span>
        )}
      </span>
      <span class="row-sub clamp2">
        {languages.map((l) => <span data-lang={l}>{summary(l)}</span>)}
      </span>
    </span>
  </a>
) : (
  <a class="card hov guide-tile" href={href} data-event={`guide:${guide.slug}`}>
    <span class="photo" style="height:64px;" aria-hidden="true">{code ? <span class="vbadge">{code}</span> : <Icon name={categoryIcon[guide.category] ?? 'visa'} size={26} class="glyph-ico" />}</span>
    <span class="pill-tag" data-i18n={catKey}>{t(catKey, defaultLang)}</span>
    <span class="card-title clamp2" style="display:block;margin-top:8px;font-size:13px;">
      {languages.map((l) => <span data-lang={l}>{title(l)}</span>)}
    </span>
  </a>
)}
