---
/**
 * <head> SEO tags. Single-URL + client language toggle for now, so each page is
 * self-canonical. When per-language URLs (/ko, /my) are added later, emit
 * <link rel="alternate" hreflang="..."> for each locale here (structure ready).
 */
interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
}

const DEFAULT_DESC =
  'MyanMate helps Myanmar people settle in Korea — clear guides on visas, housing, jobs and daily life, plus honest, in-person help. Information and guidance only.';

const { title, description = DEFAULT_DESC, canonicalPath, image = '/og-default.png' } = Astro.props;

const site = Astro.site;
const path = canonicalPath ?? Astro.url.pathname;
const canonical = site ? new URL(path, site).href : path;
const ogImage = site ? new URL(image, site).href : image;
const fullTitle = title ? `${title} · MyanMate` : 'MyanMate · Your mate for settling in Korea';
---
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<meta property="og:type" content="website" />
<meta property="og:site_name" content="MyanMate" />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
