---
import LangToggle from './LangToggle.astro';
import { t, defaultLang } from '../i18n/ui';
import { SHOW_BLOG_IN_NAV, SHOW_REVIEWS } from '../config/launch';

interface Props {
  active?: string;
}
const { active } = Astro.props;

const links = [
  { key: 'nav.home', href: '/', id: 'home' },
  { key: 'nav.guides', href: '/guides', id: 'guides' },
  ...(SHOW_BLOG_IN_NAV ? [{ key: 'nav.blog', href: '/blog', id: 'blog' }] : []),
  { key: 'nav.services', href: '/services', id: 'services' },
  ...(SHOW_REVIEWS ? [{ key: 'nav.reviews', href: '/reviews', id: 'reviews' }] : []),
  { key: 'nav.about', href: '/about', id: 'about' },
];
---
<header class="bar">
  <div class="bar-inner">
    <a class="logo" href="/">
      <span class="logo-mark" aria-hidden="true">M</span>
      <span class="logo-type">
        MyanMate
        <span class="tag" data-i18n="nav.logoTag">{t('nav.logoTag', defaultLang)}</span>
      </span>
    </a>
    <div class="grow"></div>
    <nav class="nav-links" aria-label={t('ui.nav.primary', defaultLang)} data-i18n-aria="ui.nav.primary">
      {links.map((l) => (
        <a class:list={['nl', { active: active === l.id }]} href={l.href} data-i18n={l.key}>{t(l.key, defaultLang)}</a>
      ))}
    </nav>
    <LangToggle />
    <button
      class="ham"
      type="button"
      data-nav-toggle
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Menu"
      data-i18n-aria="ui.menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav class="mobile-nav" id="mobile-nav" aria-label={t('ui.nav.mobile', defaultLang)} data-i18n-aria="ui.nav.mobile">
    {links.map((l) => (
      <a class:list={['nl', { active: active === l.id }]} href={l.href} data-i18n={l.key}>{t(l.key, defaultLang)}</a>
    ))}
  </nav>
</header>
